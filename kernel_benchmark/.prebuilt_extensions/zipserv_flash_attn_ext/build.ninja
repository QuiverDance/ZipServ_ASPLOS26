ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda/bin/nvcc

cflags = -DTORCH_EXTENSION_NAME=zipserv_flash_attn_ext -DTORCH_API_INCLUDE_EXTENSION_H -I/home/pjw7200/ZipServ_ASPLOS26/csrc -I/home/pjw7200/ZipServ_ASPLOS26/kernel_benchmark/third_party/flash_attn_v283/csrc/flash_attn/src -I/home/pjw7200/ZipServ_ASPLOS26/kernel_benchmark/third_party/flash_attn_v283/csrc/flash_attn_ck -isystem /home/pjw7200/ls/lib/python3.13/site-packages/torch/include -isystem /home/pjw7200/ls/lib/python3.13/site-packages/torch/include/torch/csrc/api/include -isystem /usr/local/cuda/include -isystem /home/pjw7200/ls/include/python3.13 -fPIC -std=c++17 -O3 -std=c++17
post_cflags = 
cuda_cflags = -DTORCH_EXTENSION_NAME=zipserv_flash_attn_ext -DTORCH_API_INCLUDE_EXTENSION_H -I/home/pjw7200/ZipServ_ASPLOS26/csrc -I/home/pjw7200/ZipServ_ASPLOS26/kernel_benchmark/third_party/flash_attn_v283/csrc/flash_attn/src -I/home/pjw7200/ZipServ_ASPLOS26/kernel_benchmark/third_party/flash_attn_v283/csrc/flash_attn_ck -isystem /home/pjw7200/ls/lib/python3.13/site-packages/torch/include -isystem /home/pjw7200/ls/lib/python3.13/site-packages/torch/include/torch/csrc/api/include -isystem /usr/local/cuda/include -isystem /home/pjw7200/ls/include/python3.13 -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr -gencode=arch=compute_86,code=sm_86 --compiler-options '-fPIC' -O3 --use_fast_math --std=c++17 -lineinfo -std=c++17
cuda_post_cflags = 
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = -shared -L/home/pjw7200/ls/lib/python3.13/site-packages/torch/lib -lc10 -lc10_cuda -ltorch_cpu -ltorch_cuda -ltorch -ltorch_python -L/usr/local/cuda/lib64 -lcudart

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags





rule link
  command = $cxx $in $ldflags -o $out

build zipserv_flash_api.o: compile /home/pjw7200/ZipServ_ASPLOS26/kernel_benchmark/third_party/flash_attn_v283/csrc/flash_attn_ck/zipserv_flash_api.cpp
build zipserv_fwd_kvcache.cuda.o: cuda_compile /home/pjw7200/ZipServ_ASPLOS26/kernel_benchmark/third_party/flash_attn_v283/csrc/flash_attn_ck/zipserv_fwd_kvcache.cu





build zipserv_flash_attn_ext.so: link zipserv_flash_api.o zipserv_fwd_kvcache.cuda.o

default zipserv_flash_attn_ext.so
